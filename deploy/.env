# ─────────────────────────────────────────────────────────
# Horizon CRM — Production Environment Variables
# Copy to .env and fill in values before deploying
# ─────────────────────────────────────────────────────────

# ── Database (external MySQL / MariaDB) ──────────────────
DB_HOST=mariadb
DB_PORT=3306
DB_ROOT_PASSWORD=changeme_db_root_password

# ── Frappe Site ──────────────────────────────────────────
FRAPPE_SITE_NAME=horizon.localhost
ADMIN_PASSWORD=changeme_admin_password

# ── Redis (container hostnames — no need to change) ─────
REDIS_CACHE_HOST=redis-cache
REDIS_QUEUE_HOST=redis-queue

# ── Nginx ────────────────────────────────────────────────
HTTP_PORT=80

# ── Performance Tuning ───────────────────────────────────
# Gunicorn workers (auto-detected if blank; max 4)
GUNICORN_WORKERS=
# Worker queue name (default: default,short,long)
WORKER_QUEUE=default,short,long
