{
	"name": "Horizon CRM Demo",
	"dockerComposeFile": "./docker-compose.yml",
	"service": "frappe",
	"workspaceFolder": "/workspace/horizon_crm",
	"remoteUser": "frappe",
	"onCreateCommand": "bash /workspace/horizon_crm/.devcontainer/init.sh",
	"postStartCommand": "bash /workspace/horizon_crm/.devcontainer/start.sh",
	"forwardPorts": [8080, 8000],
	"portsAttributes": {
		"8080": {
			"label": "Horizon CRM (nginx)",
			"onAutoForward": "openBrowser",
			"visibility": "public"
		},
		"8000": {
			"label": "Bench Dev Server",
			"onAutoForward": "silent",
			"visibility": "public"
		}
	},
	"shutdownAction": "stopCompose",
	"settings": {
		"terminal.integrated.defaultProfile.linux": "bash"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.vscode-pylance",
				"charliermarsh.ruff"
			]
		},
		"codespaces": {
			"openFiles": ["docs/DEMO.md"]
		}
	}
}
